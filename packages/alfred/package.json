{
  "name": "pi-alfred",
  "version": "0.1.0",
  "description": "Alfred π — multi-agent orchestration for pi using De Bono's cognitive hats",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "hats/",
    "skills/"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  }
}
