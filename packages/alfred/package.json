{
  "name": "pi-alfred",
  "version": "0.1.0",
  "description": "Alfred π — multi-agent orchestration for pi using De Bono's cognitive hats",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src/",
    "hats/",
    "skills/"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@types/bun": "^1.3.14",
    "@types/node": "^22",
    "typescript": "^5.9.3"
  }
}
